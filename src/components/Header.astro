---
---
<header class="shell-top">
	<div class="shell-inner">
		<a href="/" class="brand">g4ng/blog</a>
		<span class="sep"></span>
		<span class="muted"><kbd>esc</kbd> clear filters</span>
		<span class="spacer"></span>
		<button class="theme-btn" id="theme-toggle" aria-label="Toggle theme">◑ dark</button>
	</div>
</header>

<script>
	const btn = document.getElementById('theme-toggle');
	const html = document.documentElement;

	function getTheme(): string {
		return html.getAttribute('data-theme') || 'dark';
	}

	function setTheme(t: string) {
		html.setAttribute('data-theme', t);
		localStorage.setItem('theme', t);
		if (btn) btn.textContent = t === 'dark' ? '◑ dark' : '◐ light';
	}

	if (btn) {
		btn.textContent = getTheme() === 'dark' ? '◑ dark' : '◐ light';
		btn.addEventListener('click', () => setTheme(getTheme() === 'dark' ? 'light' : 'dark'));
	}
</script>
